# Environment Configuration for SpikeAI Hackathon
# Copy this file to .env and fill in your actual values

# LiteLLM API Configuration
LITELLM_API_KEY=sk-your-api-key-here
LITELLM_BASE_URL=http://your-litellm-proxy-url

# SEO Configuration
SEO_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit

# Google Credentials (Optional - place credentials.json in project root)
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json